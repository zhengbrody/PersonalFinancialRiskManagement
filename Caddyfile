# Caddyfile
#
# SITE_HOST is injected by docker compose from `.env`. Format: <eip-dashes>.nip.io
# (nip.io is a free wildcard DNS that resolves any.matching.ip.nip.io back to
# that IP; lets us get a real Let's Encrypt cert without owning a domain).
#
# Caddy auto-issues + auto-renews via the HTTP-01 challenge on :80, which
# FoundationStack's SG already opens to the world.
#
# Streamlit needs the WebSocket upgrade headers (auto-handled by Caddy's
# reverse_proxy when both ends speak WS). The longer read_timeout keeps the
# server-sent-events stream alive during long-running analyses.

# Listen on both apex (mindmarket.app) and the www subdomain so users
# typing either URL get the same response. Caddy auto-signs separate
# Let's Encrypt certs for each — one HTTP-01 challenge per name.
# When SITE_HOST is the nip.io fallback, www.<eip>.nip.io also works
# transparently since *.nip.io resolves the same way.
{$SITE_HOST}, www.{$SITE_HOST} {
	encode gzip
	log {
		output stdout
		format json
	}

	# Redirect www → apex so SEO + bookmarks settle on a single canonical URL.
	@www host www.{$SITE_HOST}
	redir @www https://{$SITE_HOST}{uri} permanent

	@brand_assets path /favicon.ico /favicon.png /favicon.svg /favicon-192.png /favicon-512.png /apple-touch-icon.png /site.webmanifest
	handle @brand_assets {
		root * /srv/brand
		header Cache-Control "public, max-age=86400"
		file_server
	}

	handle /robots.txt {
		header Content-Type "text/plain; charset=utf-8"
		respond `User-agent: *
Allow: /
Sitemap: https://{$SITE_HOST}/sitemap.xml
`
	}

	handle /sitemap.xml {
		header Content-Type "application/xml; charset=utf-8"
		respond `<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  <url>
    <loc>https://{$SITE_HOST}/</loc>
    <changefreq>weekly</changefreq>
    <priority>1.0</priority>
  </url>
  <url>
    <loc>https://{$SITE_HOST}/about</loc>
    <changefreq>monthly</changefreq>
    <priority>0.8</priority>
  </url>
  <url>
    <loc>https://{$SITE_HOST}/portfolio-risk-management</loc>
    <changefreq>monthly</changefreq>
    <priority>0.9</priority>
  </url>
  <url>
    <loc>https://{$SITE_HOST}/ai-portfolio-analysis</loc>
    <changefreq>monthly</changefreq>
    <priority>0.85</priority>
  </url>
  <url>
    <loc>https://{$SITE_HOST}/portfolio-var-stress-testing</loc>
    <changefreq>monthly</changefreq>
    <priority>0.85</priority>
  </url>
  <url>
    <loc>https://{$SITE_HOST}/Legal</loc>
    <changefreq>monthly</changefreq>
    <priority>0.4</priority>
  </url>
</urlset>
`
	}

	handle /googlecpW5HG50AaWNMEfTxdGBF6JxeviA-0QFaHDYS0xw_N8.html {
		header Content-Type "text/plain; charset=utf-8"
		respond "google-site-verification: googlecpW5HG50AaWNMEfTxdGBF6JxeviA-0QFaHDYS0xw_N8.html"
	}

	handle /about {
		root * /srv/seo
		rewrite * /about.html
		file_server
	}

	handle /portfolio-risk-management {
		root * /srv/seo
		rewrite * /portfolio-risk-management.html
		file_server
	}

	handle /ai-portfolio-analysis {
		root * /srv/seo
		rewrite * /ai-portfolio-analysis.html
		file_server
	}

	handle /portfolio-var-stress-testing {
		root * /srv/seo
		rewrite * /portfolio-var-stress-testing.html
		file_server
	}

	handle {
		reverse_proxy app:8501 {
			# Keep the WebSocket / SSE stream alive for slow analyses.
			transport http {
				read_timeout 300s
				write_timeout 300s
			}
		}
	}
}

# When SITE_HOST is unset (first boot, before deploy script writes .env),
# serve a holding page on :80 so health probes don't bounce. Caddy can't
# auto-TLS without a hostname so we don't expose :443 here.
:80 {
	respond "MindMarket bootstrap pending" 503
}
